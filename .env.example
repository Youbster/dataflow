# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Spotify (from developer.spotify.com)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Claude AI (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Encryption key for Spotify tokens (64-char hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string

# Cron secret for background sync webhook
CRON_SECRET=your_random_secret

# App URL (for OAuth redirects and share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
